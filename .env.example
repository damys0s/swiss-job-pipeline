# ============================================================
# .env.example — Variables d'environnement requises
# Copier ce fichier en .env et remplir les valeurs.
# Ne jamais committer le fichier .env !
# ============================================================

# --- Stage 1 : Fine-tuning du classificateur ---
# Requis uniquement pour réentraîner le modèle (optionnel si modèle déjà fine-tuné)
OPENAI_API_KEY=sk-...

# --- Stage 1 : Collecte du corpus d'entraînement ---
# Requis uniquement pour collecter de nouvelles offres brutes
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key
SERPAPI_KEY=your_serpapi_key

# --- Stage 2 : RAG assistant ---
# Requis pour les notebooks et l'évaluation du RAG
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY déjà défini ci-dessus (partagé avec stage 1)

# --- Stage 3 : Agent de veille quotidienne ---
# OPENAI_API_KEY, ADZUNA_APP_ID, ADZUNA_APP_KEY, SERPAPI_KEY déjà définis ci-dessus

# Gmail (compte expéditeur des alertes)
# Utiliser un "App Password" Gmail (16 caractères) — PAS le mot de passe du compte
EMAIL_ADDRESS=your.sender@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Destinataire des alertes emploi
EMAIL_TO=your.recipient@gmail.com
