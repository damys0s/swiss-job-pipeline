# Copier à la RACINE du repo : swiss-job-pipeline/.env
# (docker-compose.yml charge automatiquement ../.env via env_file ou variables shell)
# Ne jamais committer le .env réel.

# --- Adzuna ---
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# --- SerpApi ---
SERPAPI_KEY=your_serpapi_key

# --- OpenAI (classificateur fine-tuné) ---
OPENAI_API_KEY=sk-...

# --- Email (compte Gmail + App Password) ---
EMAIL_ADDRESS=moncompte@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_TO=destinataire@gmail.com

# --- Optionnel : backup cloud ---
# BACKUP_CLOUD_PATH=C:/Users/Dam/OneDrive/Documents/job_backups
